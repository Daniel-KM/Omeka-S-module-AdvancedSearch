msgstr "ID ar vammenn gentañ da adindeksetiñ"

#: view/advanced-search/admin/search-engine/index-confirm.phtml:103
msgid "Maximum number of resources to index"
msgstr "An niver brasañ a vammennoù da endeksañ"

#: view/advanced-search/admin/search-engine/index-confirm.phtml:108
msgid "Start offset"
msgstr "Deroù digempenn"

#: view/advanced-search/admin/search-engine/index-confirm.phtml:113
msgid "Limit indexing to a resource type"
msgstr "Bevennit an endeksadur d'ur seurt danvez"

#: view/advanced-search/admin/search-engine/index-confirm.phtml:122
