<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\ItemRepresentation $resource
 * @var string $type       search|collection|selection
 * @var string $subtype    free tag (theme-specific)
 * @var string $label      search query, item set title or selection title
 * @var string $contextUrl link back to the browse context
 * @var int    $position
 * @var int    $total      number of ids stored for the context (bounded)
 * @var int    $totalResults total number of results in the underlying browse
 * @var int    $limit      max stored ids
 * @var \Omeka\Api\Representation\ItemRepresentation|null $prev
 * @var \Omeka\Api\Representation\ItemRepresentation|null $next
 * @var string $prevUrl
 * @var string $nextUrl
 * @var bool $showLabel
 * @var int|null $itemSetId
 * @var int|null $selectionId
 * @var \Omeka\Api\Representation\ItemSetRepresentation|null $itemSet
 * @var mixed $selection
 * @var array $display    parts to render: type_label, context_label, position
 */

$plugins = $this->getHelperPluginManager();
$escape = $plugins->get('escapeHtml');
$translate = $plugins->get('translate');

switch ($type) {
    case 'search':
        $typeLabel = $translate('Search'); // @translate
        break;
    case 'collection':
        $typeLabel = $translate('Collection'); // @translate
        break;
    case 'selection':
        $typeLabel = $translate('Selection'); // @translate
        break;
    case 'featured':
        $typeLabel = $translate('Featured'); // @translate
        break;
    default:
        $typeLabel = $translate('Browse'); // @translate
        break;
}

$display = $display ?? ['type_label', 'context_label', 'position'];
$showType = in_array('type_label', $display, true);
$showName = in_array('context_label', $display, true);
$showPos = in_array('position', $display, true);

$hasLabel = $label !== '';
$navAriaLabel = $hasLabel ? $typeLabel . ' : ' . $label : $typeLabel;
$prevTitle = $escape($translate('Previous')); // @translate
$nextTitle = $escape($translate('Next')); // @translate
?>

<div class="block block-resource block-resource-nav browse-controls type-<?= $escape($type) ?><?= $subtype ? ' subtype-' . $escape($subtype) : '' ?>">
    <nav class="resource-nav pagination" aria-label="<?= $escape($navAriaLabel) ?>">
        <?php if ($contextUrl && ($showType || ($showName && $hasLabel))): ?>
        <a class="resource-nav-context" href="<?= $escape($contextUrl) ?>">
            <?php if ($showType): ?><?= $escape($typeLabel) ?><?php endif; ?><?php if ($showType && $showName && $hasLabel): ?> : <?php endif; ?><?php if ($showName && $hasLabel): ?><?= $escape($label) ?><?php endif; ?>
        </a>
        <?php endif; ?>
        <?php if ($showPos): ?>
        <span class="page-position" aria-label="<?= $escape(sprintf($translate('Item %1$d of %2$d'), $position, $totalResults)) ?>">
            <span class="page-input-top"><?= $position ?></span>
            <span aria-hidden="true">/</span>
            <span class="page-count"><?= $totalResults ?></span>
        </span>
        <?php endif; ?>
        <div class="pagination-buttons">
            <?php if ($prev): ?>
            <a class="previous o-icon-prev button" aria-label="<?= $prevTitle ?>" href="<?= $escape($prevUrl) ?>"></a>
            <?php else: ?>
            <span class="previous o-icon-prev button inactive" aria-hidden="true"></span>
            <?php endif; ?>
            <?php if ($next): ?>
            <a class="next o-icon-next button" aria-label="<?= $nextTitle ?>" href="<?= $escape($nextUrl) ?>"></a>
            <?php else: ?>
            <span class="next o-icon-next button inactive" aria-hidden="true"></span>
            <?php endif; ?>
        </div>
    </nav>
</div>
