<?php
/**
 * @var \Laminas\View\Renderer\PhpRenderer $this
 * @var array $filters
 * @var bool $show_field_label
 * @var string $mode "readonly" | "link_remove" | "links"
 */

if (!count($filters)) return;

$plugins = $this->getHelperPluginManager();
$escape = $plugins->get('escapeHtml');
$translate = $plugins->get('translate');
$escapeAttr = $plugins->get('escapeHtmlAttr');

$showFieldLabel = $show_field_label ?? true;
$mode = $mode ?? 'link_remove';

$classes = 'search-filters search-filters-' . str_replace('_', '-', $mode);
?>

<ul class="<?= $escapeAttr($classes) ?>">
    <?php foreach ($filters as $filterLabel => $filterValues): ?>
    <li class="filter">
        <?php if ($showFieldLabel): ?>
        <span class="filter-label"><?= $escape($filterLabel) ?></span>
        <?php endif; ?>
        <?php foreach ($filterValues as $urlQuery => $filterValue):
            $hasUrl = is_string($urlQuery) && $urlQuery !== '' && !is_numeric($urlQuery);
        ?>
            <?php if ($mode === 'links' && $hasUrl): ?>
            <a href="<?= $escapeAttr($urlQuery) ?>" class="filter-value"><?= $escape($filterValue) ?></a>
            <?php else: ?>
            <span class="filter-value"><?= $escape($filterValue) ?></span>
                <?php if ($mode === 'link_remove' && $hasUrl): ?>
                <a href="<?= $escapeAttr($urlQuery) ?>" class="filter-remove" aria-label="<?= $escapeAttr($translate('Remove this filter')) ?>" title="<?= $escapeAttr($translate('Remove this filter')) ?>">×</a>
                <?php endif; ?>
            <?php endif; ?>
        <?php endforeach; ?>
    </li>
    <?php endforeach; ?>
</ul>
